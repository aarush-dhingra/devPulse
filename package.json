{
  "name": "devvitals",
  "version": "0.1.0",
  "private": true,
  "description": "DevVitals — full-stack developer analytics dashboard with community features.",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "dev": "npm-run-all -p dev:server dev:client",
    "build:client": "npm --prefix client run build",
    "migrate": "npm --prefix server run migrate",
    "worker": "npm --prefix server run worker",
    "install:all": "npm --prefix server install && npm --prefix client install"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
